# .env.development
VITE_DOMAIN=localhost
VITE_URL=http://localhost:3001
VITE_API_URL=http://localhost:3000
VITE_SESSION_COOKIE_NAME=session_id_dev
VITE_STATE_COOKIE_NAME=state_dev
VITE_DISCORD_GUILD_ID=
POSTGRES_CONNECTION_STRING=postgresql://nexus-users:<password>@localhost:<port>/nexus-users
POSTGRES_NEXUS_CONNECTION_STRING=postgresql://nexus:<password>@localhost:<port>/nexus
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=
INTERNAL_API_URL=http://localhost:3000

# Short-domain canonical redirect
SHORT_REDIRECT_ENABLED=true
SHORT_REDIRECT_HOSTS=eunex.us,www.eunex.us
CANONICAL_PUBLIC_URL=https://entropianexus.com

# Image uploads directory (must be an absolute path in production/Docker)
# In Docker, this should point to the mounted volume: /app/uploads
UPLOAD_DIR=./uploads

# Content creator enrichment (YouTube + Twitch)
# YouTube Data API v3 key (optional — RSS works without it, API adds channel name/avatar)
# Get from https://console.cloud.google.com/ > APIs & Services > Credentials
YOUTUBE_API_KEY=
# Twitch app credentials (required for Twitch profile + live stream detection)
# Get from https://dev.twitch.tv/console/apps
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=

# Cloudflare Turnstile (bot protection for exchange orders, auctions)
# Get keys from https://dash.cloudflare.com/ > Turnstile
PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
