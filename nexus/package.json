{
	"name": "my-app",
	"version": "0.0.1",
	"private": true,
	"scripts": {
		"dev": "cross-env NODE_ENV=development npx dotenv-cli -e .env.development -- vite dev",
		"build": "cross-env NODE_ENV=production npx dotenv-cli -e .env.production -- vite build",
		"preview": "cross-env NODE_ENV=production npx dotenv-cli -e .env.production -- vite preview",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch"
	},
	"devDependencies": {
		"@sveltejs/adapter-auto": "^3.0.0",
		"@sveltejs/adapter-node": "^5.0.1",
		"@sveltejs/kit": "^2.0.0",
		"@sveltejs/vite-plugin-svelte": "^3.0.0",
		"cross-env": "^7.0.3",
		"dotenv": "^16.4.5",
		"dotenv-cli": "^7.4.1",
		"svelte": "^4.2.7",
		"svelte-check": "^3.6.0",
		"tslib": "^2.4.1",
		"typescript": "^5.0.0",
		"vite": "^5.0.3"
	},
	"type": "module",
	"dependencies": {
		"svg-path-to-polygons": "^0.1.0"
	}
}
