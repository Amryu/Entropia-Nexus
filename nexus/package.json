{
	"name": "my-app",
	"version": "0.0.1",
	"private": true,
	"scripts": {
		"dev": "cross-env NODE_ENV=development npx dotenv-cli -e .env.development -- vite dev --host 127.0.0.1 --port 3001",
		"build:prod": "cross-env NODE_ENV=production npx dotenv-cli -e .env -- vite build",
		"build:dev": "cross-env NODE_ENV=development npx dotenv-cli -e .env -- vite build --mode=development",
		"preview": "cross-env NODE_ENV=production npx dotenv-cli -e .env -- vite preview",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json && npm run verify:short-routes",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"verify:short-routes": "node scripts/verify-short-route-coverage.mjs",
		"test:short-url": "node --test tests/short-url/short-url.node.js",
		"debug": "cross-env NODE_ENV=development npx dotenv-cli -e .env -- node --inspect-brk node_modules/vite/bin/vite.js dev --host 127.0.0.1",
		"test": "playwright test",
		"test:ui": "playwright test --ui",
		"test:headed": "playwright test --headed",
		"test:report": "playwright show-report",
		"test:setup-db": "npx tsx tests/global-setup.ts"
	},
	"devDependencies": {
		"@playwright/test": "^1.58.0",
		"@sveltejs/adapter-auto": "^3.0.0",
		"@sveltejs/adapter-node": "^5.0.1",
		"@sveltejs/kit": "^2.16.0",
		"@sveltejs/vite-plugin-svelte": "^5.0.0",
		"cross-env": "^7.0.3",
		"dotenv-cli": "^7.4.1",
		"svelte": "^5.0.0",
		"svelte-check": "^4.0.0",
		"tslib": "^2.4.1",
		"tsx": "^4.7.0",
		"typescript": "^5.0.0",
		"vite": "^6.0.0"
	},
	"type": "module",
	"dependencies": {
		"@aws-sdk/client-s3": "^3.1005.0",
		"@tiptap/core": "^3.18.0",
		"@tiptap/extension-image": "^3.18.0",
		"@tiptap/extension-link": "^3.18.0",
		"@tiptap/pm": "^3.18.0",
		"@tiptap/starter-kit": "^3.18.0",
		"ajv": "^8.12.0",
		"chart.js": "^4.5.1",
		"chartjs-adapter-date-fns": "^3.0.0",
		"date-fns": "^4.1.0",
		"dompurify": "^3.3.1",
		"dotenv": "^16.4.5",
		"leaflet": "^1.9.4",
		"leaflet-draw": "^1.0.4",
		"markdown-it": "^14.1.1",
		"pg": "^8.11.5",
		"sanitize-html": "^2.17.0",
		"sharp": "^0.34.5",
		"svelte-easy-crop": "^5.0.0",
		"svg-path-to-polygons": "^0.1.0",
		"uuid": "^9.0.1"
	},
	"overrides": {
		"minimatch": "^10.2.1",
		"cookie": "^0.7.0"
	}
}
