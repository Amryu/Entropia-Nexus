# Registry and image settings
REGISTRY=ghcr.io
IMAGE_OWNER=amryu
# Use a specific image tag (e.g., commit SHA) built by CI
IMAGE_TAG=<GITHUB_SHA>

# Project directory on the server where docker-compose.yml resides
PROJECT_DIR=/opt/entropia-nexus

# Common folder source to replace on server before starting containers
# Either point to an extracted directory or a tar.gz archive
# COMMON_SRC_DIR=/tmp/common
COMMON_SRC_ARCHIVE=/tmp/common.tar.gz

# Optional: aggressively remove old images before pulling
CLEAN_OLD_IMAGES=true
