## Local deployment configuration (used by deploy.sh / Deploy.ps1)

# Absolute path to the project on the server (default: current directory)
PROJECT_DIR=/opt/entropia-nexus

# Build mode for Nexus: development | production
BUILD_MODE=production

# Compose env file to generate and pass with `docker compose --env-file`
COMPOSE_ENV_FILE=deploy/compose.env

# Paths for bind-mounted configuration and shared data on the server
COMMON_HOST_PATH=/opt/entropia-nexus/common
API_ENV_PATH=/opt/entropia-nexus/api/.env
NEXUS_ENV_PATH=/opt/entropia-nexus/nexus/.env
BOT_ENV_PATH=/opt/entropia-nexus/nexus-bot/.env
BOT_CONFIG_PATH=/opt/entropia-nexus/nexus-bot/config.json

# Copy the repo ./common folder contents into COMMON_HOST_PATH before starting
SYNC_COMMON_FROM_REPO=true

# Git update options (optional)
GIT_PULL=false
GIT_REMOTE=origin
# GIT_BRANCH=master
